{
  "manifest_version": 3,
  "name": "InfoHash Tracker",
  "version": "1.1",
  "description": "Tracks clicked magnet info hashes and marks pages already downloaded.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "InfoHash Tracker",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["capture-magnet.js"]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["check-infohash.js"]
    }
  ]
}